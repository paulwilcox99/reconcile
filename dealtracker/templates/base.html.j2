<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% block title %}DealTracker Report{% endblock %}</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
         font-size: 13px; color: #222; background: #fff; padding: 24px; }
  h1 { font-size: 22px; color: #1a1a2e; margin-bottom: 6px; }
  h2 { font-size: 16px; color: #333; margin: 20px 0 8px; border-bottom: 1px solid #ddd; padding-bottom: 4px; }
  h3 { font-size: 14px; color: #444; margin: 14px 0 6px; }
  .meta { color: #666; font-size: 12px; margin-bottom: 20px; }
  table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
  th { background: #1a1a2e; color: #fff; padding: 7px 10px; text-align: left; font-size: 12px; }
  td { padding: 6px 10px; border-bottom: 1px solid #e8e8e8; vertical-align: top; }
  tr:nth-child(even) td { background: #f9f9f9; }
  .amount { text-align: right; font-family: monospace; }
  .status-clean { color: #2e7d32; font-weight: bold; }
  .status-incomplete { color: #e65100; font-weight: bold; }
  .status-over_billed, .status-under_billed, .status-disputed { color: #c62828; font-weight: bold; }
  .status-over_paid, .status-under_paid { color: #e65100; font-weight: bold; }
  .status-missing_docs { color: #6a1b9a; font-weight: bold; }
  .status-open { color: #1565c0; }
  .status-reconciled { color: #2e7d32; }
  .status-closed { color: #757575; }
  .reconcile-box { border: 1px solid #ddd; border-radius: 4px; padding: 14px; margin-bottom: 20px; }
  .reconcile-box.has-issues { border-color: #c62828; background: #fff8f8; }
  .reconcile-box.clean { border-color: #2e7d32; background: #f8fff8; }
  .discrepancy { color: #c62828; margin-top: 8px; font-size: 12px; }
  .discrepancy li { margin: 3px 0; }
  .footer { color: #999; font-size: 11px; margin-top: 30px; border-top: 1px solid #eee; padding-top: 10px; }
  a { color: #1565c0; text-decoration: none; }
  a:hover { text-decoration: underline; }
  .badge { display: inline-block; padding: 2px 7px; border-radius: 10px;
           font-size: 11px; font-weight: bold; color: #fff; }
  .badge-green { background: #2e7d32; }
  .badge-yellow { background: #e65100; }
  .badge-red { background: #c62828; }
  .badge-gray { background: #757575; }
  @media print {
    body { padding: 10px; }
    a { color: #000; }
  }
</style>
</head>
<body>
{% block content %}{% endblock %}
<div class="footer">Generated by DealTracker on {{ generated_at }}</div>
</body>
</html>
